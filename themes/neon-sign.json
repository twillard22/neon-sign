  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": { "foreground": "#6b5a8a", "fontStyle": "italic" }
    },
    {
      "name": "Default text / variables",
      "scope": ["variable", "variable.other", "variable.other.readwrite", "variable.parameter"],
      "settings": { "foreground": "#5ee2ff" }
    },
    {
      "name": "Variable - constant",
      "scope": ["variable.other.constant", "variable.language.constant"],
      "settings": { "foreground": "#ff7a3d" }
    },
    {
      "name": "Property / object key",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": { "foreground": "#5ee2ff" }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.export",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.return",
        "keyword.other"
      ],
      "settings": { "foreground": "#ff3d8a" }
    },
    {
      "name": "Storage (let, const, function, class)",
      "scope": ["storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#ff3d8a" }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": { "foreground": "#ff5edb" }
    },
    {
      "name": "Function name",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic",
        "meta.function-call entity.name.function",
        "variable.function"
      ],
      "settings": { "foreground": "#5dff8f" }
    },
    {
      "name": "Method call",
      "scope": ["meta.function-call.method", "variable.function.method"],
      "settings": { "foreground": "#5dff8f" }
    },
    {
      "name": "Function parameter",
      "scope": ["variable.parameter", "meta.parameter"],
      "settings": { "foreground": "#ffb547", "fontStyle": "italic" }
    },
    {
      "name": "Type / class / interface",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.enum",
        "entity.name.namespace",
        "support.type",
        "support.class",
        "meta.type.annotation",
        "storage.type.class",
        "storage.type.interface",
        "storage.type.enum"
      ],
      "settings": { "foreground": "#b266ff" }
    },
    {
      "name": "Built-in types",
      "scope": [
        "support.type.builtin",
        "support.type.primitive",
        "storage.type.primitive",
        "storage.type.built-in"
      ],
      "settings": { "foreground": "#b266ff", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": { "foreground": "#ffb547" }
    },
    {
      "name": "Template string interpolation",
      "scope": [
        "string.template meta.template.expression",
        "punctuation.definition.template-expression"
      ],
      "settings": { "foreground": "#ff5edb" }
    },
    {
      "name": "Escape characters",
      "scope": ["constant.character.escape", "string source"],
      "settings": { "foreground": "#ff5edb" }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp"],
      "settings": { "foreground": "#ff5edb" }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric", "constant.numeric.integer", "constant.numeric.float"],
      "settings": { "foreground": "#ff7a3d" }
    },
    {
      "name": "Boolean / null / undefined",
      "scope": [
        "constant.language.boolean",
        "constant.language.true",
        "constant.language.false",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language"
      ],
      "settings": { "foreground": "#ff7a3d" }
    },
    {
      "name": "Decorator / annotation",
      "scope": [
        "meta.decorator",
        "meta.decorator variable.other.readwrite",
        "punctuation.decorator",
        "entity.name.function.decorator",
        "meta.annotation"
      ],
      "settings": { "foreground": "#ff5edb", "fontStyle": "italic" }
    },
    {
      "name": "Macro / preprocessor",
      "scope": ["entity.name.function.preprocessor", "meta.preprocessor", "keyword.control.directive"],
      "settings": { "foreground": "#ff5edb" }
    },
    {
      "name": "Built-in constants / globals",
      "scope": [
        "support.constant",
        "support.variable",
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": { "foreground": "#ff5edb", "fontStyle": "italic" }
    },
    {
      "name": "Labels (loop labels, jump targets)",
      "scope": ["entity.name.label"],
      "settings": { "foreground": "#ff5edb" }
    },
    {
      "name": "Tag (HTML/JSX/XML)",
      "scope": ["entity.name.tag", "meta.tag.sgml", "punctuation.definition.tag"],
      "settings": { "foreground": "#ff3d8a" }
    },
    {
      "name": "Tag attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#5dff8f", "fontStyle": "italic" }
    },
    {
      "name": "JSX/TSX component",
      "scope": ["support.class.component", "support.class.component.jsx"],
      "settings": { "foreground": "#b266ff" }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.section",
        "punctuation.definition.parameters",
        "punctuation.definition.array",
        "punctuation.definition.block",
        "punctuation.definition.bracket",
        "meta.brace"
      ],
      "settings": { "foreground": "#9a87b8" }
    },
    {
      "name": "Markup heading",
      "scope": ["markup.heading", "markup.heading entity.name", "entity.name.section"],
      "settings": { "foreground": "#ff3d8a", "fontStyle": "bold" }
    },
    {
      "name": "Markup bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#ffb547", "fontStyle": "bold" }
    },
    {
      "name": "Markup italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#b266ff", "fontStyle": "italic" }
    },
    {
      "name": "Markup quote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#6b5a8a", "fontStyle": "italic" }
    },
    {
      "name": "Markup link",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#5ee2ff", "fontStyle": "underline" }
    },
    {
      "name": "Markup inline code",
      "scope": ["markup.inline.raw", "markup.raw.inline"],
      "settings": { "foreground": "#5dff8f" }
    },
    {
      "name": "Markup list bullet",
      "scope": ["markup.list", "punctuation.definition.list.begin"],
      "settings": { "foreground": "#ff5edb" }
    },
    {
      "name": "Markup inserted (diff)",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#5dff8f" }
    },
    {
      "name": "Markup deleted (diff)",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#ff4d6d" }
    },
    {
      "name": "Markup changed (diff)",
      "scope": ["markup.changed"],
      "settings": { "foreground": "#5ee2ff" }
    },
    {
      "name": "JSON key",
      "scope": ["support.type.property-name.json", "meta.structure.dictionary.json string.quoted.double"],
      "settings": { "foreground": "#5ee2ff" }
    },
    {
      "name": "JSON string value",
      "scope": ["meta.structure.dictionary.value.json string.quoted.double"],
      "settings": { "foreground": "#ffb547" }
    },
    {
      "name": "CSS property name",
      "scope": ["support.type.property-name.css", "meta.property-name.css"],
      "settings": { "foreground": "#5ee2ff" }
    },
    {
      "name": "CSS property value",
      "scope": ["support.constant.property-value.css", "meta.property-value.css"],
      "settings": { "foreground": "#ffb547" }
    },
    {
      "name": "CSS selector",
      "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#ff3d8a" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#ff4d6d", "fontStyle": "underline" }
    },
    {
      "name": "Invalid deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#ffb547", "fontStyle": "italic underline" }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#b266ff",
    "class": "#b266ff",
    "class.defaultLibrary": "#b266ff",
    "interface": "#b266ff",
    "enum": "#b266ff",
    "enumMember": "#ff7a3d",
    "struct": "#b266ff",
    "type": "#b266ff",
    "type.defaultLibrary": "#b266ff",
    "typeParameter": "#b266ff",
    "parameter": "#ffb547",
    "variable": "#5ee2ff",
    "variable.readonly": "#ff7a3d",
    "variable.defaultLibrary": "#ff5edb",
    "property": "#5ee2ff",
    "property.readonly": "#5ee2ff",
    "property.static": "#5ee2ff",
    "function": "#5dff8f",
    "function.defaultLibrary": "#5dff8f",
    "method": "#5dff8f",
    "method.defaultLibrary": "#5dff8f",
    "macro": "#ff5edb",
    "label": "#ff5edb",
    "decorator": "#ff5edb",
    "keyword": "#ff3d8a",
    "modifier": "#ff3d8a",
    "operator": "#ff5edb",
    "string": "#ffb547",
    "number": "#ff7a3d",
    "boolean": "#ff7a3d",
    "regexp": "#ff5edb",
    "comment": "#6b5a8a",
    "*.deprecated": { "strikethrough": true }
  }
}
