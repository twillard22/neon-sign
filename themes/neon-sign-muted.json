  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": { "foreground": "#8a7ba8", "fontStyle": "italic" }
    },
    {
      "name": "Default text / variables",
      "scope": ["variable", "variable.other", "variable.other.readwrite", "variable.parameter"],
      "settings": { "foreground": "#8fcde0" }
    },
    {
      "name": "Variable - constant",
      "scope": ["variable.other.constant", "variable.language.constant"],
      "settings": { "foreground": "#e89870" }
    },
    {
      "name": "Property / object key",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": { "foreground": "#8fcde0" }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.export",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.return",
        "keyword.other"
      ],
      "settings": { "foreground": "#e87aa8" }
    },
    {
      "name": "Storage (let, const, function, class)",
      "scope": ["storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#e87aa8" }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": { "foreground": "#d090c8" }
    },
    {
      "name": "Function name",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic",
        "meta.function-call entity.name.function",
        "variable.function"
      ],
      "settings": { "foreground": "#8de0a5" }
    },
    {
      "name": "Method call",
      "scope": ["meta.function-call.method", "variable.function.method"],
      "settings": { "foreground": "#8de0a5" }
    },
    {
      "name": "Function parameter",
      "scope": ["variable.parameter", "meta.parameter"],
      "settings": { "foreground": "#e8c074", "fontStyle": "italic" }
    },
    {
      "name": "Type / class / interface",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.enum",
        "entity.name.namespace",
        "support.type",
        "support.class",
        "meta.type.annotation",
        "storage.type.class",
        "storage.type.interface",
        "storage.type.enum"
      ],
      "settings": { "foreground": "#b896d8" }
    },
    {
      "name": "Built-in types",
      "scope": [
        "support.type.builtin",
        "support.type.primitive",
        "storage.type.primitive",
        "storage.type.built-in"
      ],
      "settings": { "foreground": "#b896d8", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": { "foreground": "#e8c074" }
    },
    {
      "name": "Template string interpolation",
      "scope": [
        "string.template meta.template.expression",
        "punctuation.definition.template-expression"
      ],
      "settings": { "foreground": "#d090c8" }
    },
    {
      "name": "Escape characters",
      "scope": ["constant.character.escape", "string source"],
      "settings": { "foreground": "#d090c8" }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp"],
      "settings": { "foreground": "#d090c8" }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric", "constant.numeric.integer", "constant.numeric.float"],
      "settings": { "foreground": "#e89870" }
    },
    {
      "name": "Boolean / null / undefined",
      "scope": [
        "constant.language.boolean",
        "constant.language.true",
        "constant.language.false",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language"
      ],
      "settings": { "foreground": "#e89870" }
    },
    {
      "name": "Decorator / annotation",
      "scope": [
        "meta.decorator",
        "meta.decorator variable.other.readwrite",
        "punctuation.decorator",
        "entity.name.function.decorator",
        "meta.annotation"
      ],
      "settings": { "foreground": "#d090c8", "fontStyle": "italic" }
    },
    {
      "name": "Macro / preprocessor",
      "scope": ["entity.name.function.preprocessor", "meta.preprocessor", "keyword.control.directive"],
      "settings": { "foreground": "#d090c8" }
    },
    {
      "name": "Built-in constants / globals",
      "scope": [
        "support.constant",
        "support.variable",
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": { "foreground": "#d090c8", "fontStyle": "italic" }
    },
    {
      "name": "Labels (loop labels, jump targets)",
      "scope": ["entity.name.label"],
      "settings": { "foreground": "#d090c8" }
    },
    {
      "name": "Tag (HTML/JSX/XML)",
      "scope": ["entity.name.tag", "meta.tag.sgml", "punctuation.definition.tag"],
      "settings": { "foreground": "#e87aa8" }
    },
    {
      "name": "Tag attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#8de0a5", "fontStyle": "italic" }
    },
    {
      "name": "JSX/TSX component",
      "scope": ["support.class.component", "support.class.component.jsx"],
      "settings": { "foreground": "#b896d8" }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.section",
        "punctuation.definition.parameters",
        "punctuation.definition.array",
        "punctuation.definition.block",
        "punctuation.definition.bracket",
        "meta.brace"
      ],
      "settings": { "foreground": "#9a8cb0" }
    },
    {
      "name": "Markup heading",
      "scope": ["markup.heading", "markup.heading entity.name", "entity.name.section"],
      "settings": { "foreground": "#e87aa8", "fontStyle": "bold" }
    },
    {
      "name": "Markup bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#e8c074", "fontStyle": "bold" }
    },
    {
      "name": "Markup italic",
